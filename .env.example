# ── Core ──────────────────────────────────────────────
DATABASE_URL=postgresql://sourceiq:sourceiq@localhost:5432/sourceiq
PORT=3333
NODE_ENV=development
JWT_SECRET=change-me-in-production
DEMO_MODE=false
ALLOW_MOCK_CONNECTORS=false
REQUIRE_DATABASE=true

# ── Infrastructure ────────────────────────────────────
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:19092
USE_KAFKA=true
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=sourceiq
USE_CLICKHOUSE=true

# ── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Sourcing: real APIs (at least one discovery path) ─
GITHUB_TOKEN=
STACKOVERFLOW_KEY=
TAVILY_API_KEY=
PROXYCURL_API_KEY=

# LinkedIn via Proxycurl person search, or Tavily site:linkedin.com/in
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Naukri Resdex (employer API) or Tavily fallback
NAUKRI_API_KEY=
NAUKRI_API_URL=https://www.naukri.com/recruit/api/v1

# Indeed Resume Search (partner) or Tavily fallback
INDEED_PUBLISHER_ID=
INDEED_API_KEY=
INDEED_API_BASE=https://api.indeed.com/ads

# Internal talent pool HTTP API
ATS_INTERNAL_API_URL=
ATS_INTERNAL_API_TOKEN=

# ── Outreach (SMTP) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── ATS export ────────────────────────────────────────
GREENHOUSE_API_KEY=
GREENHOUSE_ON_BEHALF_OF=
LEVER_API_KEY=

# ── Seed ──────────────────────────────────────────────
SEED_PASSWORD=password
